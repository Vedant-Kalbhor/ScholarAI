# AI Research Assistant Configuration

# Frontend API base URL
VITE_API_URL=http://localhost:8000

# Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Optional fallback after Gemini)
GROQ_API_KEY=your_groq_api_key_here

# Optional model overrides
GEMINI_MODEL=gemini-3.5-flash
GROQ_MODEL=llama-3.1-70b-versatile
OLLAMA_MODEL=llama3:latest

# SerpApi Key (Optional, for Google Scholar search)
SERPAPI_API_KEY=your_serpapi_key_here

# Zotero API Key (Optional)
ZOTERO_API_KEY=your_zotero_api_key_here
ZOTERO_USER_ID=your_zotero_user_id_here

# Vector Database Path
VECTOR_DB_PATH=./data/chromadb

# Backend CORS origins for production and local dev
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-vercel-app.vercel.app

# Use Gemini embeddings instead of the local fallback
USE_GEMINI_EMBEDDINGS=false
GEMINI_EMBEDDING_MODEL=text-embedding-004
